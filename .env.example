# Copy this file to .env and fill in values for local overrides.
# DATABASE_URL and OLLAMA_BASE_URL are already set in docker-compose.yml for
# local dev — only set them here if you need to override the defaults.

# DATABASE_URL=postgresql+psycopg://dnd_dm:dnd_dm@localhost:5432/dnd_dm
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# CHROMA_PERSIST_DIR=data/chroma_db

# In-game DM agent model — one model, two roles: mechanics (tool-calling,
# low temp) and narrator (prose, high temp, no tools). Must be pulled
# locally in Ollama.
# MECHANICS_MODEL=gemma4:26b-mlx
