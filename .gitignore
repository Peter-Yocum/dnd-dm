# Environment
.env
.venv/

# Per-host Compose override — see docker-compose.gpu.yml's header comment.
# A GPU host symlinks docker-compose.gpu.yml to this name; a Mac dev
# checkout never has one. Either way it's machine-specific, never committed.
docker-compose.override.yml
__pycache__/
*.pyc
*.pyo

# Data — never commit DB contents or embeddings (top-level only — backend/data/ is
# source code, e.g. spells.py/equipment.py, not runtime data, and must stay tracked)
/data/

# Alembic ignores compiled migrations but keeps version files
alembic/versions/*.pyc

# Docs — raw scanned PDFs can be large. Source markdown (docs/source/) is
# OCR'd copyrighted rulebook/adventure text (WotC), not redistributed here —
# regenerate it from your own legally-owned PDFs via scripts/ocr_ingest.py +
# scripts/build_index.py.
docs/raw/
docs/source/

# Stray archives
*.tar.gz

# macOS
.DS_Store

# IDEs
.vscode/
.idea/
scripts/spikes/
